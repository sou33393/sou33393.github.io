# 이 파일을 복사해서 .env 로 저장한 뒤 실제 값을 채워넣으세요.
# .env 파일은 절대 git에 커밋하지 마세요 (.gitignore에 이미 포함되어 있음).

# 네이버 개발자센터 (https://developers.naver.com/apps/#/register) 에서 발급
# 사용 API: 검색 > 뉴스
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# 카카오 디벨로퍼스 (https://developers.kakao.com) 에서 발급
KAKAO_REST_API_KEY=your_kakao_rest_api_key
KAKAO_REFRESH_TOKEN=your_kakao_refresh_token

# 한국은행 ECOS (https://ecos.bok.or.kr/api/#/DevGuide/CenterCode) 에서 발급
ECOS_API_KEY=your_ecos_api_key

# 선택 설정 (기본값 사용해도 무방)
KAKAO_TOKEN_CACHE_PATH=.kakao_tokens.json
ECOS_CACHE_PATH=.ecos_cache.json
MAX_ARTICLE_AGE_HOURS=30
REQUEST_TIMEOUT=10
MAX_RETRIES=3

# 브리핑 웹페이지 URL (선택). 비워두면 GitHub Actions에서는 저장소 정보로 자동 계산되고,
# 로컬 테스트에서는 실제 GitHub Pages 주소를 알고 있을 때만 지정하면 됩니다.
# 예: https://your-id.github.io/daily-briefing/
BRIEFING_PAGE_URL=
